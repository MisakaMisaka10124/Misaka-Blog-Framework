{
  "server": {
    "port": 3000,
    "frontend_dir": "../src/views"
  },
  "admin": {
    "username": "admin",
    "password": "YOUR_PASSWORD_HERE"
  },
  "jwt": {
    "secret": "YOUR_JWT_SECRET_HERE",
    "expires_in": "24h"
  },
  "captcha": {
    "size": 4,
    "noise": 2,
    "color": true,
    "background": "#f0f0f0",
    "expires_in_ms": 300000
  },
  "rate_limit": {
    "ai_chat": {
      "window_ms": 3600000,
      "max_requests": 30,
      "message": "当前IP发送过多请求，请稍后再试。"
    },
    "data_api": {
      "window_ms": 60000,
      "max_requests": 120,
      "message": "请求过于频繁，请稍后再试。"
    }
  },
  "paths": {
    "posts_dir": "./data/posts/",
    "ai_knowledge": "./ai_knowlage.json",
    "site_config": "./site_config.json"
  },
  "ai": {
    "base_url": "https://your-ai-api-endpoint.com/v1",
    "api_key": "YOUR_API_KEY_HERE",
    "model": "YOUR_MODEL_NAME",
    "fallback_prompt": "你是一个友好的助手。",
    "simulate_reply": false
  },
  "marked_options": {
    "gfm": true,
    "breaks": true
  },
  "display": {
    "homePostsPerPage": 5,
    "searchResultsPerPage": 10,
    "categoriesPostsPerPage": 5,
    "maxSocialLinks": 4,
    "maxHeroBackgrounds": 6,
    "dashboardRecentPostsCount": 5,
    "maxTagSuggestions": 8,
    "wordCountUnit": "字"
  },
  "imageCompression": {
    "maxWidth": 1920,
    "quality": 0.82
  },
  "hero": {
    "backgroundMode": "timeOfDay",
    "staticBackground": "/images/morning.jpg",
    "backgroundTimeRanges": {
      "morning": [5, 11],
      "noon": [11, 16],
      "evening": [16, 22],
      "night": [22, 5]
    },
    "backgroundRotationInterval": 300000,
    "backgroundCheckInterval": 60000,
    "minHeight": 420,
    "mobileMinHeight": 320
  },
  "defaults": {
    "avatar": "/images/avatar1.jpg",
    "friendAvatar": "/images/avatar1.jpg",
    "socialIcon": "/images/social/github.svg",
    "siteTitle": "Misaka"
  },
  "fallbackImages": {
    "heroBackgrounds": {
      "default": [
        "/images/morning.jpg",
        "/images/noon.jpg",
        "/images/evening.jpg",
        "/images/night.jpg"
      ],
      "custom": []
    },
    "socialIcons": [
      { "id": "github", "name": "GitHub", "url": "/images/social/github.svg" },
      { "id": "bilibili", "name": "Bilibili", "url": "/images/social/bilibili.svg" },
      { "id": "twitter", "name": "Twitter/X", "url": "/images/social/twitter.svg" },
      { "id": "email", "name": "邮箱", "url": "/images/social/email.svg" }
    ]
  }
}
